# FinEye config — copy to `.env` and fill in
FINEYE_DATA_DIR=data
FINEYE_WAL_DIR=.wal
FINEYE_TMP_DIR=.tmp
FINEYE_DEFAULT_TIMEZONE=Asia/Kolkata
FINEYE_DEFAULT_CURRENCY=INR
FINEYE_LOG_LEVEL=INFO

# LLM — Groq (groq.com, fast LPU inference). Wired in M2; leave blank for stub.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Sheets (M6). See docs/SHEETS_SETUP.md.
# Master switch — leave false to completely disable the mirror + worker.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_MAX_RETRIES=6
GOOGLE_SHEETS_BACKOFF_BASE=1.0
