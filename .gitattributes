# Normalize line endings to LF in the repo, check out LF on all platforms
* text=auto eol=lf
*.py text eol=lf
*.html text eol=lf
*.js text eol=lf
*.css text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.woff binary
